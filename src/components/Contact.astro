---
// Sección contacto
---

<section class="section" id="contacto">
  <div class="contact-layout fade-in">
    <div>
      <div class="section-label">Contacto</div>
      <div class="contact-intro">¿Hablamos<br />de <em>algo</em>?</div>
      <p class="contact-desc">Para booking, notas de prensa, entrevistas y colaboraciones. Respondemos en menos de 48 horas.</p>
    </div>
    <div class="contact-cards">
      <a class="contact-card" href="mailto:booking@ericamorelo.com">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2"></rect><path d="m22 7-10 7L2 7"></path></svg>
        </div>
        <div class="contact-card-info">
          <div class="contact-card-type">Booking</div>
          <div class="contact-card-val">booking@ericamorelo.com</div>
        </div>
      </a>
      <a class="contact-card" href="mailto:prensa@ericamorelo.com">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2z"></path><path d="M16 2v4H8"></path><path d="M8 18h8"></path><path d="M8 14h8"></path><path d="M8 10h4"></path></svg>
        </div>
        <div class="contact-card-info">
          <div class="contact-card-type">Prensa</div>
          <div class="contact-card-val">prensa@ericamorelo.com</div>
        </div>
      </a>
      <a class="contact-card" href="https://ericamorelo.com" target="_blank" rel="noopener">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
        </div>
        <div class="contact-card-info">
          <div class="contact-card-type">Web</div>
          <div class="contact-card-val">ericamorelo.com</div>
        </div>
      </a>
      <a class="contact-card" href="https://instagram.com/ericamorelo" target="_blank" rel="noopener">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"></rect><circle cx="12" cy="12" r="5"></circle><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle></svg>
        </div>
        <div class="contact-card-info">
          <div class="contact-card-type">Instagram</div>
          <div class="contact-card-val">@ericamorelo</div>
        </div>
      </a>
    </div>
  </div>
</section>
