---
// Sección videos
---

<section class="section" id="videos">
  <div class="section-label">Audiovisual</div>
  <h2 class="section-title">Videos</h2>
  <div class="videos-grid fade-in">
    <div class="video-card">
      <div class="video-thumb">
        <div class="video-bg"></div>
        <div class="play-circle">
          <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
        </div>
        <div class="video-duration">4:02</div>
      </div>
      <div class="video-title">Río de enero — Videoclip oficial</div>
      <div class="video-sub">1.2M vistas · Dirección: Maia Sosa</div>
    </div>
    <div class="video-card">
      <div class="video-thumb">
        <div class="video-bg" style="background: linear-gradient(160deg,#f0d8de 0%,#fef0ec 100%)"></div>
        <div class="play-circle">
          <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
        </div>
        <div class="video-duration">5:47</div>
      </div>
      <div class="video-title">Cartografía — En vivo · Teatro Colón</div>
      <div class="video-sub">840K vistas · Buenos Aires, 2023</div>
    </div>
    <div class="video-card">
      <div class="video-thumb">
        <div class="video-bg" style="background: linear-gradient(160deg,#f5e8d6 0%,#fef0ec 100%)"></div>
        <div class="play-circle">
          <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
        </div>
        <div class="video-duration">3:28</div>
      </div>
      <div class="video-title">Noche de verano — Lyric video</div>
      <div class="video-sub">510K vistas</div>
    </div>
    <div class="video-card">
      <div class="video-thumb">
        <div class="video-bg" style="background: linear-gradient(160deg,#f5d6e8 0%,#fef0ec 100%)"></div>
        <div class="play-circle">
          <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
        </div>
        <div class="video-duration">22:14</div>
      </div>
      <div class="video-title">Mini documental — Aluvión: el proceso</div>
      <div class="video-sub">280K vistas · Behind the scenes</div>
    </div>
  </div>
</section>
