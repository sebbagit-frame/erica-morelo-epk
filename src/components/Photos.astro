---
// Sección galería de fotos de prensa
---

<section class="section" id="fotos">
  <div class="section-label">Galería de prensa</div>
  <h2 class="section-title">Fotos</h2>
  <div class="photo-grid fade-in">
    <div class="photo-placeholder photo-large">
      <div class="photo-gradient"></div>
      <div class="photo-overlay">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
      </div>
      <div class="photo-label">Foto 1 — Aquí va tu foto</div>
    </div>
    <div class="photo-placeholder">
      <div class="photo-gradient" style="background: linear-gradient(160deg,#f0d8de 0%,#fef0ec 100%)"></div>
      <div class="photo-overlay">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
      </div>
      <div class="photo-label">Foto 2</div>
    </div>
    <div class="photo-placeholder">
      <div class="photo-gradient" style="background: linear-gradient(160deg,#f5e8d6 0%,#fef0ec 100%)"></div>
      <div class="photo-overlay">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
      </div>
      <div class="photo-label">Foto 3</div>
    </div>
    <div class="photo-placeholder">
      <div class="photo-gradient" style="background: linear-gradient(160deg,#f5d6e8 0%,#fef0ec 100%)"></div>
      <div class="photo-overlay">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
      </div>
      <div class="photo-label">Foto 4</div>
    </div>
  </div>
  <div class="photo-download">
    <a class="btn-outline" href="#" download>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
      Descargar todas (ZIP)
    </a>
  </div>
</section>
